{
  "name": "security-doctor",
  "version": "0.1.1",
  "description": "Security-focused CLI tool for JS/TS codebases — catches the vulnerabilities AI coding agents actually introduce, and installs its rules as guidance for your coding agent.",
  "type": "module",
  "bin": {
    "security-doctor": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nkd52/security-doctor.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "security",
    "static-analysis",
    "sast",
    "cli",
    "ai-coding-agent",
    "vulnerability-scanner",
    "sql-injection",
    "xss",
    "taint-tracking"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "clipboardy": "^5.3.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
