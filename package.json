{
  "name": "security-doctor",
  "version": "1.0.0",
  "description": "Security-focused CLI tool for JS/TS codebases",
  "main": "dist/index.js",
  "bin": {
    "security-doctor": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
